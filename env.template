# Copy this file to .env.local and fill in your values
# NEVER commit .env.local or .env to git

# Neon Database (postgresql connection string)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Celo network: "celo" (mainnet) or "celo-alfajores" (testnet)
NEXT_PUBLIC_CELO_NETWORK=celo-alfajores

# Platform fee wallet — receives the 0.5% fee from every payment
# Must be a valid 0x address on the active Celo network
NEXT_PUBLIC_PLATFORM_FEE_WALLET=0xYOUR_WALLET_ADDRESS_HERE

# Platform fee in basis points (50 = 0.5%, 100 = 1%). Default: 50
NEXT_PUBLIC_PLATFORM_FEE_BPS=50

# x402 facilitator URL for payment settlement (Solvador supports Celo mainnet)
X402_FACILITATOR_URL=https://api.solvador.com

# Optional: dedicated RPC endpoints (public fallbacks are used otherwise)
# CELO_RPC_URL=
# CELO_ALFAJORES_RPC_URL=
